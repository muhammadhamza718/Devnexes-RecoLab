# Keep the .gitignore files themselves
!.agents/agents/.gitignore
!.agents/commands/.gitignore
!.agents/skills/.gitignore
!.claude/agents/.gitignore
!.claude/commands/.gitignore
!.claude/skills/.gitignore
!.kiro/agents/.gitignore
